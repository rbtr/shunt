# Copy to .env and fill in. Used by examples/docker-compose.yml and local runs.
SHUNT_INSTANCE=https://forge.example.com
SHUNT_TOKEN=

# Multi-repo mode: manage every repo carrying this topic.
SHUNT_TOPIC=merge-queue
# ...or single-repo mode (use one or the other):
# SHUNT_REPO=owner/repo

# Optional tuning (defaults shown):
# SHUNT_BOT_USER=mq-bot
# SHUNT_MERGE_STYLE=merge  # merge, squash, or rebase; must be enabled in repo settings
# SHUNT_MAX_BATCH=0
# SHUNT_BATCH_LINGER=0
# SHUNT_BATCH_TARGET=0
# SHUNT_BISECT_FANOUT=1
# SHUNT_POLL_INTERVAL=10s
# SHUNT_LISTEN=:8080
# SHUNT_WEBHOOK_SECRET=
